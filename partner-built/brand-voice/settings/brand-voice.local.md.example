---
# 品牌声音插件设置
# 将此文件复制到 .claude/brand-voice.local.md 并填入您的值。
# 必填字段：company_name。所有其他字段均为可选，有合理的默认值。
company_name: ""          # 必填
platforms:
  notion: true
  confluence: false
  google-drive: false
  box: false
  microsoft-365: false
  figma: false
  gong: false
  granola: false
  slack: false
discovery:
  search-depth: standard    # standard | deep
  max-sources: 15
enforcement:
  strictness: balanced      # strict | balanced | flexible
  always-explain: true
open-questions:
  share-with-team: false
---
# 品牌背景

